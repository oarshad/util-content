<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <property name="charset" value="UTF-8"/>

    <!-- Allows suppression file -->
    <module name="SuppressionFilter">
        <property name="file" value="${checkstyle.suppressions.file}"/>
        <property name="optional" value="true"/>
    </module>

    <!-- Block System.out / System.err -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.(out|err)\.print"/>
        <property name="message" value="Use the project logger instead of System.out/System.err"/>
        <property name="ignoreComments" value="true"/>
    </module>

    <!-- Block printStackTrace -->
    <module name="RegexpSingleline">
        <property name="format" value="\.printStackTrace\s*\("/>
        <property name="message" value="Use logger with exception argument instead of printStackTrace()"/>
        <property name="ignoreComments" value="true"/>
    </module>

    <!-- Block java.util.logging if you use SLF4J/Logback -->
    <module name="RegexpSingleline">
        <property name="format" value="import\s+java\.util\.logging\."/>
        <property name="message" value="Use SLF4J/project logger instead of java.util.logging"/>
        <property name="ignoreComments" value="true"/>
    </module>

    <module name="TreeWalker">

        <!-- Prevent catch(Throwable t) -->
        <module name="IllegalCatch">
            <property name="illegalClassNames" value="Throwable"/>
        </module>

        <!-- You can enable this later if you want to ban catch(Exception) too -->
        <!--
        <module name="IllegalCatch">
            <property name="illegalClassNames" value="Exception, RuntimeException, Throwable"/>
        </module>
        -->

        <!-- Empty catch/finally/etc. blocks -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
            <property name="tokens" value="LITERAL_CATCH,LITERAL_FINALLY,LITERAL_IF,LITERAL_ELSE,LITERAL_TRY"/>
        </module>

    </module>
</module>