<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Example: ignore generated sources -->
    <suppress files=".*[/\\]target[/\\]generated-sources[/\\].*" checks=".*"/>

    <!-- Example: allow System.out in command-line main classes if needed -->
    <!--
    <suppress files=".*[/\\]src[/\\]main[/\\]java[/\\].*Main\.java" checks="RegexpSingleline"/>
    -->
</suppressions>